apiVersion: v1
kind: Service
metadata:
  name: {{ name }}
  namespace: {{ namespace }}
  labels:
    app: {{ name }}
    managed-by: zenml
    {% if labels %}
    {% for key, value in labels.items() %}
    {{ key }}: {{ value | tojson }}
    {% endfor %}
    {% endif %}
spec:
  type: {{ settings.service_type }}
  selector:
    # Select on the deployment-id and managed-by labels used by the
    # Deployment's matchLabels, not the `app` label which can be
    # overwritten by user-supplied `labels` or `pod_settings.labels`
    # on the pod template and leave the Service with no endpoints.
    managed-by: zenml
    zenml-deployment-id: {{ labels.get('zenml-deployment-id') | tojson }}
  ports:
    - port: {{ settings.service_port }}
      targetPort: {{ settings.service_port }}
      protocol: TCP
      name: http
